# Firebase Configuration
# Firebaseコンソールから取得した設定情報を入力してください
# https://console.firebase.google.com/

# Firebase API Key（公開されても安全）
FIREBASE_API_KEY=AIzaSyBxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Auth Domain
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID
FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ==========================================
# AI プロバイダー (MANDARA Insight 用)
# ==========================================
# 現在は Gemini のみ対応。ユーザーが画面から入力したキーは
# ブラウザの localStorage に保存されるため、この値は参考情報です。
#
# 将来的にビルド時注入を行う場合の命名規則:

# アクティブプロバイダー (現在は gemini のみ。将来: claude | openai)
ACTIVE_AI_PROVIDER=gemini

# Gemini API キー (https://aistudio.google.com/apikey で取得)
GEMINI_API_KEY=AIza...

# 将来対応予定
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ==========================================
# 使い方
# ==========================================
#
# ローカル開発:
#   このファイルはVanilla JavaScriptでは直接使用できません。
#   js/firebase-config.js に直接設定を記述してください。
#
# Netlify/Vercel などのデプロイ環境:
#   環境変数として設定できますが、ビルドプロセスが必要です。
#   現在の構成では js/firebase-config.js を直接編集してください。
#
# AI キーについて:
#   MANDARA Insight のAI分析で使うキーは、アプリの画面から
#   ユーザーが個別に入力する方式です (localStorage保存)。
#   env からの読み込みには未対応です。
#
# セキュリティ:
#   Firebase APIキーは公開されても安全です。
#   実際のセキュリティはFirestoreのセキュリティルールで管理されます。
#   Gemini APIキーはユーザー個別のもので、localStorageに保存されます。
#
